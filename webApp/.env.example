# Copy to .env and fill in real values. .env is gitignored.
# Load these into the environment before running (or use a process manager / systemd).

# Flask session signing key. Generate a strong random value for any real deployment:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Full SQLAlchemy/Postgres connection string.
# Local dev default (used if unset): postgresql://postgres:Ateam123@localhost:5432/ateam
DATABASE_URL=

# Outbound email (IONOS) account passwords. Leave blank locally to disable sending.
MAIL_NOREPLY_PASSWORD=
MAIL_EXAMS_PASSWORD=
