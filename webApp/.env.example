# Copy to .env and fill in real values. .env is gitignored.
# Load these into the environment before running (or use a process manager / systemd).

# Flask session signing key. Generate a strong random value for any real deployment:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Full SQLAlchemy/Postgres connection string.
# Local dev default (used if unset): postgresql://postgres:Ateam123@localhost:5432/ateam
DATABASE_URL=

# Outbound email (IONOS) account passwords. Leave blank locally to disable sending.
MAIL_NOREPLY_PASSWORD=
MAIL_EXAMS_PASSWORD=

# --- Stripe prepayment (optional; feature stays dormant until both are set) ---
# Live secret key: Stripe dashboard -> Developers -> API keys.
STRIPE_SECRET_KEY=
# Signing secret of the webhook you create pointing at .../stripe_webhook
# (Stripe dashboard -> Developers -> Webhooks).
STRIPE_WEBHOOK_SECRET=

# --- GoHighLevel CRM (optional) ----------------------------------------------
# Private Integration token (GHL sub-account -> Settings -> Private Integrations,
# Contacts write scope). Powers platform -> GHL contact sync.
GHL_PRIVATE_TOKEN=
# The GHL sub-account (location) id the contacts belong to.
GHL_LOCATION_ID=
# Long random shared secret for the inbound GHL -> platform webhook
# (POST /ghl_inbound; GHL sends it in the X-Webhook-Key header). Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
GHL_INBOUND_SECRET=

# --- rarely changed ----------------------------------------------------------
# Where the public registration form stores uploads. Leave UNSET in production
# to keep the historical /var/www/webApp/webApp/userFiles path.
# USER_FILES_DIR=
